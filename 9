CREATE OR REPLACE PROCEDURE increase_salary
IS
BEGIN
    UPDATE employee
    SET salary = salary + (salary * 0.10);

    COMMIT;

    DBMS_OUTPUT.PUT_LINE(
        'Salary increased by 10% for all employees'
    );
END;
/



BEGIN
    increase_salary;
END;
